{
  "expo": {
    "name": "Les Sources",
    "slug": "les-sources",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f7f7f7"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fr.lessources",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "fr.lessources",
      "versionCode": 1,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f7f7f7"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "apiKey": "",
      "authDomain": "",
      "databaseURL": "https://les-sources-66f43-default-rtdb.firebaseio.com",
      "projectId": "",
      "storageBucket": "",
      "messagingSenderId": "",
      "appId": "",
      "eas": {
        "projectId": "e24e48e4-21df-4732-971c-8ba0160fd366"
      }
    }
  }
}
